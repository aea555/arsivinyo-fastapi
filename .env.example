# Environment Configuration (development, production)
ENV=development

# Security Bypass for Development (Required for testing)
APP_SECRET_KEY=dev_secret_bypass

# Download Access Gate
# true  -> require DOWNLOAD_ACCESS_HEADER_NAME header on /download, /status/*, /files/*
# false -> do not require the additional download access header
REQUIRE_DOWNLOAD_ACCESS_HEADER=true
DOWNLOAD_ACCESS_HEADER_NAME=X-Download-Access
DOWNLOAD_ACCESS_KEY=change_this_download_access_key

# Firebase App Check toggle
# true  -> require and verify X-Firebase-AppCheck for non-VIP requests
# false -> do not require App Check at all
# Default behavior in code: true on production, false on development
REQUIRE_FIREBASE_APPCHECK=false

# Browser access toggle
# false -> block browser-like requests
# true  -> allow browser requests and enable CORS
ALLOW_BROWSER_ACCESS=true
CORS_ALLOWED_ORIGINS=*

# Comma-separated CORS origin allowlist when ALLOW_BROWSER_ACCESS=true
# Use * to allow all origins
CORS_ALLOWED_ORIGINS=*

# Valkey / Redis Configuration
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_JSON=/app/firebase-auth.json

# Cookie Configuration
# COOKIES_DIR=cookies
